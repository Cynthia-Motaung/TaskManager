# Copy this file to .env and replace every CHANGE_ME value.
# Compose reads .env automatically from the repository root.

# SQL Server container settings (docker-compose.yml)
MSSQL_SA_PASSWORD=CHANGE_ME_SQL_SA_PASSWORD
MSSQL_HOST_PORT=14333

# API authentication and bootstrap user settings (TaskManager)
TASKMANAGER_JWT_KEY=CHANGE_ME_32_PLUS_CHAR_JWT_KEY
SeedUsers__Enabled=true
SeedUsers__AdminEmail=admin@taskmanager.local
SeedUsers__ManagerEmail=manager@taskmanager.local
SeedUsers__AdminPassword=CHANGE_ME_ADMIN_PASSWORD
SeedUsers__ManagerPassword=CHANGE_ME_MANAGER_PASSWORD

# Required when running API against SQL Server from host shell.
# If you change MSSQL_HOST_PORT above, update the port in this value too.
ConnectionStrings__TaskConnection='Server=localhost,14333;Database=TaskManager;User ID=sa;Password=CHANGE_ME_SQL_SA_PASSWORD;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=True;'
