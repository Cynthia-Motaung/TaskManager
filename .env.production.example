# Copy to .env.production on the production host.
# Do not commit .env.production.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080
UseInMemoryDatabase=false

# Required: keep quoted if you plan to `source` this file in bash/zsh.
ConnectionStrings__TaskConnection='Server=<sql-host>,1433;Database=TaskManager;User ID=<sql-user>;Password=<strong-sql-password>;TrustServerCertificate=False;Encrypt=True;MultipleActiveResultSets=True;'

# Required: at least 32 characters.
TASKMANAGER_JWT_KEY=<replace-with-strong-random-32-plus-char-value>
Jwt__Issuer=TaskManager
Jwt__Audience=TaskManagerClients
Jwt__ExpiryMinutes=120

# Recommended after initial bootstrap.
SeedUsers__Enabled=false

# Optional one-time bootstrap values if you intentionally enable seed users.
# SeedUsers__AdminEmail=admin@taskmanager.local
# SeedUsers__ManagerEmail=manager@taskmanager.local
# SeedUsers__AdminPassword=<strong-admin-password-12-plus-char>
# SeedUsers__ManagerPassword=<strong-manager-password-12-plus-char>
