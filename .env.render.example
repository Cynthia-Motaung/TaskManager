# Copy values from this file into Render Dashboard -> Environment.
# Do not commit real secret values.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_FORWARDEDHEADERS_ENABLED=true
UseInMemoryDatabase=false
Jwt__Issuer=TaskManager
Jwt__Audience=TaskManagerClients
Jwt__ExpiryMinutes=120
SeedUsers__Enabled=false

# Secrets (set real values in Render, not in git):
TASKMANAGER_JWT_KEY=<strong-random-32-plus-char-value>
ConnectionStrings__TaskConnection=Server=<sql-host>,1433;Database=TaskManager;User ID=<sql-user>;Password=<strong-sql-password>;TrustServerCertificate=False;Encrypt=True;MultipleActiveResultSets=True;
